# server/.env

# Server
PORT=3001
NODE_ENV=development

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_analyzer
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_analyzer
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Session
SESSION_EXPIRY_HOURS=24
